       Perfect! I now have all the information needed to provide a comprehensive answer. Let me compile the documentation findings:

       How to Parse CLI Arguments Using the Args Package

       Based on the args 2.7.x documentation, here's a comprehensive guide to parsing command-line arguments:

       Main Classes

       1. ArgParser - The core class for defining and parsing command-line arguments
       2. ArgResults - The result object containing parsed values returned from ArgParser.parse()
       3. CommandRunner - High-level class for building command-based applications (optional)
       4. Command - Base class for defining individual commands (used with CommandRunner)

       Defining Options and Flags

       Creating an ArgParser

       var parser = ArgParser();
       // Optional: control trailing options and line wrapping
       var parser = ArgParser(
         allowTrailingOptions: false,  // stop parsing after first positional arg
         usageLineLength: 80  // wrap help text at 80 characters
       );

       Adding Flags (Boolean Options)

       Flags represent boolean values that can be true or false:

       parser.addFlag('verbose', abbr: 'v');  // --verbose or -v
       parser.addFlag('verbose', negatable: false);  // disable --no-verbose
       parser.addFlag('verbose', defaultsTo: true);  // default is true
       parser.addFlag('verbose', help: 'Show verbose output');  // help text

       Adding String Options

       Options that accept string values:

       parser.addOption('mode', abbr: 'm');  // --mode=value or --mode value
       parser.addOption('mode', defaultsTo: 'debug');  // default value
       parser.addOption('mode', allowed: ['debug', 'release']);  // validate values
       parser.addOption('mode', valueHelp: 'MODE');  // help text label
       parser.addOption('mode', mandatory: true);  // required option
       parser.addOption('mode', help: 'Compiler mode');  // description

       Adding Multi-Options

       Options that can be specified multiple times:

       parser.addMultiOption('include');  // --include a --include b
       parser.addMultiOption('include', splitCommas: true);  // --include a,b allowed
       parser.addMultiOption('include', defaultsTo: []);  // default empty list

       Adding Commands

       For hierarchical command structures (like git commit):

       var commitCmd = parser.addCommand('commit');
       commitCmd.addFlag('all', abbr: 'a');

       Parsing Arguments

       var results = parser.parse(['--mode', 'debug', '--verbose', 'rest', 'args']);

       For use in main():
       void main(List<String> args) {
         var parser = ArgParser();
         // ... define options ...
         var results = parser.parse(args);
       }

       Accessing Parsed Values

       Use the ArgResults object returned by parse():

       // Get flag value (boolean)
       bool verbose = results.flag('verbose');

       // Get option value (string or null)
       String? mode = results.option('mode');

       // Get multi-option values (list of strings)
       List<String> includes = results.multiOption('include');

       // Get remaining unparsed arguments
       List<String> remaining = results.rest;

       // Check if option was explicitly provided
       bool wasParsed = results.wasParsed('mode');

       // Get command that was selected
       ArgResults? command = results.command;
       if (command != null) {
         print('Command: ${command.name}');
         print('All: ${command.flag('all')}');
       }

       // Access via index operator (less type-safe)
       var value = results['mode'];

       Practical Examples

       Basic Compiler Script

       void main(List<String> args) {
         var parser = ArgParser();
         parser.addOption('mode',
             abbr: 'm',
             defaultsTo: 'debug',
             allowed: ['debug', 'release'],
             help: 'Compilation mode');
         parser.addFlag('verbose',
             abbr: 'v',
             defaultsTo: false,
             help: 'Enable verbose output');

         var results = parser.parse(args);

         print('Mode: ${results.option('mode')}');
         if (results.flag('verbose')) {
           print('Verbose mode enabled');
         }

         if (results.rest.isNotEmpty) {
           print('Files to compile: ${results.rest.join(', ')}');
         }
       }

       Command-Based Application

       void main(List<String> args) {
         var parser = ArgParser();

         // Global flag
         parser.addFlag('verbose', abbr: 'v');

         // Define commands
         var commit = parser.addCommand('commit');
         commit.addFlag('all', abbr: 'a');

         var push = parser.addCommand('push');
         push.addOption('remote', defaultsTo: 'origin');

         var results = parser.parse(args);

         if (results.command != null) {
           final cmd = results.command!;
           switch (cmd.name) {
             case 'commit':
               handleCommit(cmd.flag('all'));
               break;
             case 'push':
               handlePush(cmd.option('remote')!);
               break;
           }
         }
       }

       Command-Line Syntax

       Users can invoke your application using various formats:

       # Long options
       program --mode=debug --verbose

       # Long options with space
       program --mode debug --verbose

       # Short abbreviations
       program -m debug -v

       # Combined short flags
       program -mv

       # Negating flags
       program --no-verbose

       # Multiple values for multi-options
       program --include foo --include bar
       program --include foo,bar

       # Arguments after options
       program --mode debug file1.dart file2.dart

       # Stop parsing with --
       program --mode debug -- --not-an-option

       Help Text

       Generate usage information automatically:

       print(parser.usage);

       // With detailed help
       parser.addOption('arch',
           help: 'Architecture to compile for',
           allowedHelp: {
             'ia32': 'Intel x86',
             'arm': 'ARM 32-bit chip'
           });

       This generates formatted help messages suitable for display with --help flags.
