‚Źļ Here's how to parse CLI arguments using the args package (v2.7.x):

  Core Classes

  - ArgParser ‚ÄĒ define options, flags, and commands
  - ArgResults ‚ÄĒ access parsed values
  - CommandRunner / Command ‚ÄĒ for command-based CLIs (optional)

  Defining Options

  var parser = ArgParser();

  // Boolean flag
  parser.addFlag('verbose', abbr: 'v', help: 'Enable verbose output');

  // String option
  parser.addOption('mode',
      abbr: 'm',
      defaultsTo: 'debug',
      allowed: ['debug', 'release'],
      help: 'Compilation mode');

  // Multi-value option
  parser.addMultiOption('include', splitCommas: true);

  Parsing & Accessing Values

  void main(List<String> args) {
    var parser = ArgParser();
    parser.addFlag('verbose', abbr: 'v');
    parser.addOption('mode', defaultsTo: 'debug');

    var results = parser.parse(args);

    bool verbose = results.flag('verbose');
    String? mode = results.option('mode');
    List<String> remaining = results.rest;
    bool explicit = results.wasParsed('mode');
  }

  Commands (subcommand pattern)

  var commit = parser.addCommand('commit');
  commit.addFlag('all', abbr: 'a');

  var results = parser.parse(args);
  if (results.command?.name == 'commit') {
    print(results.command!.flag('all'));
  }

  Help Text

  print(parser.usage);  // auto-generated from help/allowedHelp metadata

  CLI Syntax Examples

  program --mode=debug --verbose
  program -m debug -v
  program --no-verbose          # negate a flag
  program --include a,b         # multi-option with commas
